<!-- Change Request Add / Edit dialog -->
<dialog id="change-dialog" aria-labelledby="change-dialog-title">
  <div class="dialog-header" id="change-dialog-title">Change Request hinzuf&uuml;gen</div>
  <form id="change-form" method="dialog">
    <div class="dialog-body">
      <input type="hidden" id="change-form-id">
      <div class="form-group">
        <label for="change-form-title">Titel *</label>
        <input type="text" id="change-form-title" required>
      </div>
      <div class="form-group">
        <label for="change-form-description">Beschreibung</label>
        <textarea id="change-form-description" rows="3"></textarea>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label for="change-form-change-type">Änderungsart</label>
          <input type="text" id="change-form-change-type" placeholder="z.B. Erweiterung SoW">
        </div>
        <div class="form-group">
          <label for="change-form-category">Kategorie</label>
          <select id="change-form-category">
            <option value="OFFEN">Offen</option>
            <option value="NON_PRIOR">Non-Prior Approval</option>
            <option value="PRIOR">Prior Approval</option>
          </select>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label for="change-form-priority">Priorit&auml;t</label>
          <select id="change-form-priority">
            <option value="LOW">Niedrig</option>
            <option value="MEDIUM" selected>Mittel</option>
            <option value="HIGH">Hoch</option>
            <option value="CRITICAL">Kritisch</option>
          </select>
        </div>
        <div class="form-group">
          <label for="change-form-requested-by">Beantragt von</label>
          <input type="text" id="change-form-requested-by">
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label for="change-form-requested-date">Antragsdatum</label>
          <input type="text" id="change-form-requested-date" placeholder="TT.MM.JJJJ" pattern="\d{2}\.\d{2}\.\d{4}" inputmode="numeric" title="TT.MM.JJJJ">
        </div>
        <div class="form-group">
          <label for="change-form-target-date">Zieldatum</label>
          <input type="text" id="change-form-target-date" placeholder="TT.MM.JJJJ" pattern="\d{2}\.\d{2}\.\d{4}" inputmode="numeric" title="TT.MM.JJJJ">
        </div>
      </div>
    </div>
    <div class="dialog-footer">
      <button type="button" class="btn btn-secondary" id="change-btn-cancel">Abbrechen</button>
      <button type="submit" class="btn btn-primary" id="change-btn-save">Speichern</button>
    </div>
  </form>
</dialog>

<!-- Change Delete confirmation -->
<dialog id="change-delete-dialog" aria-labelledby="change-delete-dialog-title">
  <div class="dialog-header" id="change-delete-dialog-title">Change Request l&ouml;schen</div>
  <div class="dialog-body">
    <p>Soll <strong id="change-delete-name"></strong> wirklich gel&ouml;scht werden?</p>
  </div>
  <div class="dialog-footer">
    <button class="btn btn-secondary" id="change-delete-cancel">Abbrechen</button>
    <button class="btn btn-danger" id="change-delete-confirm">L&ouml;schen</button>
  </div>
</dialog>

<!-- Task Add / Edit dialog -->
<dialog id="task-dialog" aria-labelledby="task-dialog-title">
  <div class="dialog-header" id="task-dialog-title">Aufgabe hinzuf&uuml;gen</div>
  <form id="task-form" method="dialog">
    <div class="dialog-body">
      <input type="hidden" id="task-form-id">
      <div class="form-group">
        <label for="task-form-process">Prozesse *</label>
        <textarea id="task-form-process" rows="2" required></textarea>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label for="task-form-area">Bereich</label>
          <input type="text" id="task-form-area" placeholder="z.B. Dokumentation, Personal, Antrag">
        </div>
        <div class="form-group">
          <label for="task-form-section-header">Abschnitts-&Uuml;berschrift</label>
          <input type="text" id="task-form-section-header" placeholder="z.B. Maschine, Piloten">
        </div>
      </div>
      <div class="form-group">
        <label for="task-form-safety-note">Sicherheitsbewertung</label>
        <input type="text" id="task-form-safety-note">
      </div>
      <div class="form-group">
        <label for="task-form-measures">eingeleitete Ma&szlig;nahmen / To Do</label>
        <textarea id="task-form-measures" rows="2"></textarea>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label for="task-form-responsible">Verantwortlich</label>
          <input type="text" id="task-form-responsible">
        </div>
        <div class="form-group">
          <label for="task-form-target-date">Zieldatum</label>
          <input type="text" id="task-form-target-date" placeholder="TT.MM.JJJJ" pattern="\d{2}\.\d{2}\.\d{4}" inputmode="numeric" title="TT.MM.JJJJ">
        </div>
      </div>
      <div class="form-group">
        <label for="task-form-completion-date">Erledigt am</label>
        <input type="text" id="task-form-completion-date" placeholder="TT.MM.JJJJ (leer = offen)" pattern="\d{2}\.\d{2}\.\d{4}" inputmode="numeric" title="TT.MM.JJJJ">
      </div>
    </div>
    <div class="dialog-footer">
      <button type="button" class="btn btn-secondary" id="task-btn-cancel">Abbrechen</button>
      <button type="submit" class="btn btn-primary" id="task-btn-save">Speichern</button>
    </div>
  </form>
</dialog>

<!-- Task Delete confirmation -->
<dialog id="task-delete-dialog" aria-labelledby="task-delete-dialog-title">
  <div class="dialog-header" id="task-delete-dialog-title">Aufgabe l&ouml;schen</div>
  <div class="dialog-body">
    <p>Soll diese Aufgabe wirklich gel&ouml;scht werden?</p>
  </div>
  <div class="dialog-footer">
