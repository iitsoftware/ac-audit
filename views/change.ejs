<!-- EASA Form 2 dialog -->
<dialog id="easa-form2-dialog" class="dialog-lg" aria-labelledby="easa-form2-dialog-title">
  <div class="dialog-header" id="easa-form2-dialog-title">EASA Form 2</div>
  <form id="easa-form2-form" method="dialog">
    <div class="dialog-body">
      <div class="form-row">
        <div class="form-group">
          <label>Antragsart</label>
          <select id="easa-form2-antragsart">
            <option value="aenderung">&Auml;nderung</option>
            <option value="erstgenehmigung">Erstgenehmigung</option>
          </select>
        </div>
        <div class="form-group" id="easa-form2-genart-group" style="display:none">
          <label>Genehmigungsart</label>
          <select id="easa-form2-genart">
            <option value="teil-145">Teil-145 Genehmigung</option>
            <option value="teil-cao">Teil-CAO Genehmigung</option>
          </select>
        </div>
        <div class="form-group">
          <label>Einverst&auml;ndnis Ver&ouml;ffentlichung</label>
          <select id="easa-form2-einverstaendnis">
            <option value="ja">Ja</option>
            <option value="nein">Nein</option>
          </select>
        </div>
      </div>
      <div class="form-group">
        <label for="easa-form2-standorte">Standort(e)</label>
        <input type="text" id="easa-form2-standorte" value="siehe oben">
      </div>
      <div class="form-row">
        <div class="form-group">
          <label for="easa-form2-telefon">Telefon</label>
          <input type="text" id="easa-form2-telefon">
        </div>
        <div class="form-group" id="easa-form2-fax-group">
          <label for="easa-form2-fax">Fax</label>
          <input type="text" id="easa-form2-fax">
        </div>
      </div>
      <hr style="border:none;border-top:1px solid var(--border);margin:12px 0 8px">
      <!-- CAMO: 4 sub-sections -->
      <div id="easa-form2-scope-camo">
        <p style="font-size:.85rem;color:var(--text-muted);margin-bottom:8px"><strong>5. Umfang der Genehmigung / &Auml;nderung</strong></p>
        <div class="form-group">
          <label for="easa-form2-scope-5a">a) Genehmigung gem. CAMO.A.125 d) / CAMO.A.130 a)</label>
          <textarea id="easa-form2-scope-5a" rows="2" placeholder="Luftfahrzeugmuster / -serien / -gruppen"></textarea>
        </div>
        <div class="form-group">
          <label for="easa-form2-scope-5b">b) Privilegien gem. CAMO.A.125 d), e), f)</label>
          <textarea id="easa-form2-scope-5b" rows="2" placeholder="z.B. Ausstellung/Verl&auml;ngerung von ARCs"></textarea>
        </div>
        <div class="form-group">
          <label for="easa-form2-scope-5c">c) Organisatorische &Auml;nderung (Personal / Meldekette)</label>
          <textarea id="easa-form2-scope-5c" rows="2" placeholder="z.B. Erweiterung der internen Berechtigungen"></textarea>
        </div>
        <div class="form-group">
          <label for="easa-form2-scope-5d">d) Sonstige &Auml;nderungen des Handbuchs (CAMO.A.300)</label>
          <textarea id="easa-form2-scope-5d" rows="2" placeholder="z.B. Aufnahme Arbeitsvorbereitung"></textarea>
        </div>
      </div>
      <!-- Part-145: single scope field -->
      <div id="easa-form2-scope-145" style="display:none">
        <div class="form-group">
          <label for="easa-form2-scope-single"><strong>5. Bedingungen und Umfang der Genehmigung</strong></label>
          <textarea id="easa-form2-scope-single" rows="4" placeholder="Bedingungen und Umfang der Genehmigung mit Bezug zu diesem Antrag"></textarea>
        </div>
      </div>
    </div>
    <div class="dialog-footer">
      <button type="button" class="btn btn-secondary" id="easa-form2-btn-cancel">Abbrechen</button>
      <button type="button" class="btn btn-secondary" id="easa-form2-btn-download">PDF herunterladen</button>
      <button type="submit" class="btn btn-primary" id="easa-form2-btn-send">Per E-Mail senden</button>
    </div>
  </form>
</dialog>

