  </div>
</dialog>

<!-- Risk Item Add / Edit dialog -->
<dialog id="risk-item-dialog" class="dialog-xl" aria-labelledby="risk-item-dialog-title">
  <div class="dialog-header" id="risk-item-dialog-title">Risiko hinzuf&uuml;gen</div>
  <form id="risk-item-form" method="dialog">
    <div class="dialog-body">
      <input type="hidden" id="risk-item-form-id">
      <div class="form-row">
        <div class="form-group">
          <label for="risk-item-form-risk-type">Risikotyp</label>
          <input type="text" id="risk-item-form-risk-type" placeholder="z.B. Hubschrauber, Mensch">
        </div>
        <div class="form-group">
          <label for="risk-item-form-responsible">Verantwortlich</label>
          <input type="text" id="risk-item-form-responsible">
        </div>
      </div>
      <div class="form-group">
        <label for="risk-item-form-description">Risikobeschreibung *</label>
        <textarea id="risk-item-form-description" rows="2" required></textarea>
      </div>
      <div class="form-group">
        <label for="risk-item-form-consequence">Auswirkung</label>
        <textarea id="risk-item-form-consequence" rows="2"></textarea>
      </div>
      <div class="form-row" style="align-items:flex-start">
        <div class="form-group" style="flex:1">
          <label>Anfangsrisiko</label>
          <div id="risk-item-matrix-initial" style="margin-top:4px"></div>
        </div>
        <div class="form-group" style="flex:1">
          <label>Restrisiko</label>
          <div id="risk-item-matrix-residual" style="margin-top:4px"></div>
        </div>
      </div>
      <div class="form-group">
        <label for="risk-item-form-mitigation">Thema der Ma&szlig;nahme</label>
        <input type="text" id="risk-item-form-mitigation">
      </div>
      <div class="form-group">
        <label for="risk-item-form-treatment">Behandlung und Kontrolle</label>
        <textarea id="risk-item-form-treatment" rows="2"></textarea>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label for="risk-item-form-impl-date">Termin f&uuml;r Umsetzung</label>
          <input type="text" id="risk-item-form-impl-date" placeholder="TT.MM.JJJJ" pattern="\d{2}\.\d{2}\.\d{4}" inputmode="numeric" title="TT.MM.JJJJ">
        </div>
        <div class="form-group">
          <label for="risk-item-form-next-step">N&auml;chster Schritt</label>
          <input type="text" id="risk-item-form-next-step">
        </div>
      </div>
    </div>
    <div class="dialog-footer">
      <button type="button" class="btn btn-secondary" id="risk-item-btn-cancel">Abbrechen</button>
      <button type="submit" class="btn btn-primary" id="risk-item-btn-save">Speichern</button>
    </div>
  </form>
</dialog>

