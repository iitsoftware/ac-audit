<div class="settings-page">
  <h1>Protokoll</h1>
  <div class="log-table-wrap">
    <table class="log-table" id="log-table">
      <thead>
        <tr>
          <th>Zeitpunkt</th>
          <th>Aktion</th>
          <th>Firma</th>
          <th>Abteilung</th>
          <th>Objekt</th>
          <th>Details</th>
        </tr>
      </thead>
      <tbody id="log-body"></tbody>
    </table>
  </div>
  <div style="text-align:center;margin-top:16px">
    <button class="btn btn-secondary" id="log-load-more" style="display:none">Mehr laden</button>
  </div>
</div>
