<!-- Company Tabs -->
<div class="tab-bar" id="company-tab-bar">
  <div class="tab-bar-scroll" id="company-tabs"></div>
  <button class="tab-add-btn" id="btn-add" title="Firma hinzuf&uuml;gen">+</button>
</div>

<!-- Hidden dept add button placeholder (used by JS) -->
<button id="btn-add-dept" style="display:none"></button>

<!-- Main Content -->
<main class="main-content-full" id="main-content">
  <div class="empty-state" id="empty-state">Firma ausw&auml;hlen</div>
  <div id="right-pane-content" style="display:none">
    <div id="org-detail"></div>
  </div>
</main>

<!-- Company Add / Edit dialog -->
<dialog id="company-dialog" aria-labelledby="dialog-title">
  <div class="dialog-header" id="dialog-title">Firma hinzuf&uuml;gen</div>
  <form id="company-form" method="dialog">
    <div class="dialog-body">
      <input type="hidden" id="form-id">
      <div class="form-group">
        <label for="form-name">Name *</label>
        <input type="text" id="form-name" required>
      </div>
      <div class="form-group">
        <label for="form-street">Stra&szlig;e</label>
        <input type="text" id="form-street">
      </div>
      <div class="form-group">
        <label for="form-postal">PLZ</label>
        <input type="text" id="form-postal">
      </div>
      <div class="form-group">
        <label for="form-city">Stadt</label>
        <input type="text" id="form-city">
      </div>
      <div class="form-row">
        <div class="form-group">
          <label for="form-phone">Telefon</label>
          <input type="text" id="form-phone" placeholder="z.B. 02382-940530-10">
        </div>
        <div class="form-group">
          <label for="form-fax">Fax</label>
          <input type="text" id="form-fax">
        </div>
      </div>
      <div class="form-group">
        <label for="form-logo">Logo</label>
        <input type="file" id="form-logo" accept="image/*">
        <div class="logo-preview-row" id="logo-preview-row" style="display:none">
          <img id="logo-preview" class="logo-preview" alt="Firmenlogo Vorschau">
          <button type="button" class="remove-logo-btn" id="remove-logo-btn">Entfernen</button>
        </div>
      </div>
      <div id="company-persons-section" style="display:none">
        <hr class="form-divider">
        <div class="form-group">
          <label>Accountable Manager</label>
          <div class="form-row">
            <input type="text" id="form-acc-firstname" placeholder="Vorname" aria-label="Accountable Manager Vorname" class="form-group">
            <input type="text" id="form-acc-lastname" placeholder="Nachname" aria-label="Accountable Manager Nachname" class="form-group">
          </div>
          <input type="email" id="form-acc-email" placeholder="E-Mail" class="form-input form-input--mt">
          <div class="sig-upload-row">
            <input type="file" id="form-acc-sig" accept="image/*" class="sig-file-input">
            <div class="logo-preview-row" id="form-acc-sig-preview-row" style="display:none">
              <img id="form-acc-sig-preview" class="sig-preview" alt="Accountable Manager Unterschrift">
              <button type="button" class="remove-logo-btn" data-sig="acc">Entfernen</button>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="dialog-footer">
      <button type="button" class="btn btn-secondary" id="btn-cancel">Abbrechen</button>
      <button type="submit" class="btn btn-primary" id="btn-save">Speichern</button>
    </div>
  </form>
</dialog>

<!-- Company Delete confirmation dialog -->
<%- include('partials/dialog', {
  id: 'delete-dialog',
  title: 'Firma l&ouml;schen',
  body: '<p>Soll <strong id="delete-name"></strong> wirklich gel&ouml;scht werden?</p>',
  footer: '<button class="btn btn-secondary" id="delete-cancel">Abbrechen</button><button class="btn btn-danger" id="delete-confirm">L&ouml;schen</button>'
}) %>

<!-- Department Add / Edit dialog -->
<dialog id="dept-dialog" aria-labelledby="dept-dialog-title">
  <div class="dialog-header" id="dept-dialog-title">Abteilung hinzuf&uuml;gen</div>
  <form id="dept-form" method="dialog">
    <div class="dialog-body">
      <input type="hidden" id="dept-form-id">
      <div class="form-group">
        <label for="dept-form-name">Name *</label>
        <input type="text" id="dept-form-name" required>
      </div>
      <div class="form-group">
        <label for="dept-form-easa">EASA Genehmigungsnummer</label>
        <input type="text" id="dept-form-easa">
      </div>
      <div class="form-group">
        <label for="dept-form-regulation">Regulation</label>
        <input type="text" id="dept-form-regulation">
      </div>
      <hr class="form-divider">
      <div class="form-group">
        <label>Zust&auml;ndige Aufsichtsperson Beh&ouml;rde</label>
        <div class="form-row">
          <select id="dept-form-authority-salutation" class="form-input form-input--auto">
            <option value="">Anrede</option>
            <option value="Herr">Herr</option>
            <option value="Frau">Frau</option>
          </select>
          <input type="text" id="dept-form-authority-name" placeholder="Name" class="form-group">
        </div>
        <input type="email" id="dept-form-authority-email" placeholder="E-Mail Betriebspr&uuml;fer" class="form-input form-input--mt">
        <input type="email" id="dept-form-initial-approval-email" placeholder="E-Mail Erstgenehmigung (z.B. RefT5@lba.de)" class="form-input form-input--mt">
      </div>
      <div id="dept-persons-section" style="display:none">
        <hr class="form-divider">
        <div class="form-group">
          <label>Compliance Monitoring Manager</label>
          <div class="form-row">
            <input type="text" id="dept-form-qm-firstname" placeholder="Vorname" aria-label="Compliance Monitoring Manager Vorname" class="form-group">
            <input type="text" id="dept-form-qm-lastname" placeholder="Nachname" aria-label="Compliance Monitoring Manager Nachname" class="form-group">
          </div>
          <input type="email" id="dept-form-qm-email" placeholder="E-Mail" class="form-input form-input--mt">
          <div class="sig-upload-row">
            <input type="file" id="dept-form-qm-sig" accept="image/*" class="sig-file-input">
            <div class="logo-preview-row" id="dept-form-qm-sig-preview-row" style="display:none">
              <img id="dept-form-qm-sig-preview" class="sig-preview" alt="Compliance Monitoring Manager Unterschrift">
              <button type="button" class="remove-logo-btn" data-sig="dept-qm">Entfernen</button>
            </div>
          </div>
        </div>
        <div class="form-group">
          <label id="dept-form-al-label">Abteilungsleiter</label>
          <div class="form-row">
            <input type="text" id="dept-form-al-firstname" placeholder="Vorname" aria-label="Abteilungsleiter Vorname" class="form-group">
            <input type="text" id="dept-form-al-lastname" placeholder="Nachname" aria-label="Abteilungsleiter Nachname" class="form-group">
          </div>
          <input type="email" id="dept-form-al-email" placeholder="E-Mail" class="form-input form-input--mt">
          <div class="sig-upload-row">
            <input type="file" id="dept-form-al-sig" accept="image/*" class="sig-file-input">
            <div class="logo-preview-row" id="dept-form-al-sig-preview-row" style="display:none">
              <img id="dept-form-al-sig-preview" class="sig-preview" alt="Abteilungsleiter Unterschrift">
              <button type="button" class="remove-logo-btn" data-sig="dept-al">Entfernen</button>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="dialog-footer">
      <button type="button" class="btn btn-secondary" id="dept-btn-cancel">Abbrechen</button>
      <button type="submit" class="btn btn-primary" id="dept-btn-save">Speichern</button>
    </div>
  </form>
</dialog>

<!-- Department Delete confirmation dialog -->
<%- include('partials/dialog', {
  id: 'dept-delete-dialog',
  title: 'Abteilung l&ouml;schen',
  body: '<p>Soll <strong id="dept-delete-name"></strong> wirklich gel&ouml;scht werden?</p>',
  footer: '<button class="btn btn-secondary" id="dept-delete-cancel">Abbrechen</button><button class="btn btn-danger" id="dept-delete-confirm">L&ouml;schen</button>'
}) %>
