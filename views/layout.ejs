<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AC Suite</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <header class="top-nav">
    <a href="/home" class="brand">AC Suite</a>
    <nav>
      <a href="/organization" class="<%= (typeof activePage !== 'undefined' && activePage === 'organization') ? 'active' : '' %>">Organisation</a>
      <a href="/companies" class="<%= (typeof activePage !== 'undefined' && activePage === 'companies') ? 'active' : '' %>">AC-Audit</a>
      <a href="/change" class="<%= (typeof activePage !== 'undefined' && activePage === 'change') ? 'active' : '' %>">AC-Change</a>
    </nav>
    <div class="nav-spacer"></div>
    <button class="nav-icon-link<%= (typeof activePage !== 'undefined' && activePage === 'trash') ? ' active' : '' %>" data-toggle-page="/trash" title="Papierkorb" aria-label="Papierkorb"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg><span class="trash-badge" id="trash-badge" style="display:none"></span></button>
    <button class="nav-icon-link<%= (typeof activePage !== 'undefined' && activePage === 'logs') ? ' active' : '' %>" data-toggle-page="/logs" title="Protokoll" aria-label="Protokoll"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg></button>
    <button class="nav-icon-link<%= (typeof activePage !== 'undefined' && activePage === 'settings') ? ' active' : '' %>" data-toggle-page="/settings" title="Einstellungen" aria-label="Einstellungen"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 01-2.83 2.83l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09a1.65 1.65 0 00-1-1.51 1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06a1.65 1.65 0 00.33-1.82 1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09a1.65 1.65 0 001.51-1 1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06a1.65 1.65 0 001.82.33H9a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06a1.65 1.65 0 00-.33 1.82V9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg></button>
    <a href="/logout" class="nav-icon-link" title="Abmelden" aria-label="Abmelden"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg></a>
  </header>
  <%- body %>
  <script src="/app.js"></script>
  <% if (typeof activePage !== 'undefined' && activePage === 'change') { %>
    <script src="/risk-matrix.js"></script>
  <% } %>
  <% if (typeof pageScript !== 'undefined' && pageScript) { %>
    <script src="/<%= pageScript %>"></script>
  <% } %>
</body>
</html>
